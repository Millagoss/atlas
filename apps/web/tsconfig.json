{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@atlas/shared": ["../../packages/shared/src/index.ts"],
      "@atlas/config": ["../../packages/config/src/index.ts"],
      "@atlas/ui": ["../../packages/ui/src/index.ts"],
      "@atlas/pipeline": ["../../packages/pipeline/src/index.ts"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "*.ts"],
  "exclude": ["node_modules", "dist", ".vinxi", ".output"],
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/config" },
    { "path": "../../packages/ui" },
    { "path": "../../packages/pipeline" }
  ]
}
